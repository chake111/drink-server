<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.drink.server.mapper.DrinkFlavorMapper">

    <select id="listByDrinkId" resultType="com.drink.server.entity.DrinkFlavor">
        SELECT id, drink_id, name, value
        FROM drink_flavor
        WHERE drink_id = #{drinkId}
    </select>

    <insert id="insertBatch">
        INSERT INTO drink_flavor (drink_id, name, value) VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.drinkId}, #{item.name}, #{item.value})
        </foreach>
    </insert>

    <delete id="deleteByDrinkId">
        DELETE FROM drink_flavor WHERE drink_id = #{drinkId}
    </delete>

</mapper>
